{
  "name": "m365-toolbox-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "node --watch src/server.js",
    "dev:worker": "node --watch src/worker.js",
    "postinstall": "node ./scripts/prismaGenerate.js",
    "prisma:generate": "prisma generate --config ./prisma.config.ts --schema ./prisma/schema.prisma",
    "start": "npm run db:migrate && node src/server.js",
    "start:api": "npm run db:migrate && node src/server.js",
    "start:worker": "npm run db:migrate && node src/worker.js",
    "test": "npm run prisma:generate && node --test",
    "db:migrate": "node ./scripts/prismaMigrateDeploy.js",
    "db:seed": "node src/scripts/seed.js",
    "migrate:file-runs": "node src/scripts/migrateFileRuns.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "archiver": "^7.0.1",
    "bullmq": "^5.58.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ioredis": "^5.7.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "prisma": "^7.8.0"
  }
}

